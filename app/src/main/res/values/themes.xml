<resources>
    <!-- Base application theme. -->
    <style name="Theme.CuesApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <!-- Splash screen theme. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F2ECE5</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/cues_text</item>
        <item name="postSplashScreenTheme">@style/Theme.CuesApp</item>
    </style>

    <!-- Base application theme. -->
    <style name="Base.Theme.Suggestions" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/screen_background</item>
        <item name="colorSurface">@color/screen_background</item>
    </style>

    <style name="Theme.Suggestions" parent="Base.Theme.Suggestions" />
</resources>