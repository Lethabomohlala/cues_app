<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardContainer"
    android:layout_width="300dp"
    android:layout_height="350dp"
    android:layout_gravity="center"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:clickable="true"
    android:focusable="true">

    <!-- Front card -->
    <LinearLayout
        android:id="@+id/cardFront"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/card_bg_energetic"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="0dp"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvFrontTitle1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sunrise_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:src="@drawable/cloud_sugg"
            android:contentDescription="@string/mood_illustration_desc"/>

        <TextView
            android:id="@+id/tvFrontTitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hype_check_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_white_outline"
            android:text="@string/get_suggestions"
            android:textColor="#000000"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="12sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Back card -->
    <LinearLayout
        android:id="@+id/cardBack"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/card_bg_back"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="0dp"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvBackTitle1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sunrise_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/card_energetic"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvBackSuggestion1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sunrise_suggestion"
            android:textSize="12sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/or_text"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvBackTitle2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hype_check_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/card_energetic"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvBackSuggestion2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/hype_check_suggestion"
            android:textSize="12sp"
            android:textColor="#000000"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

    </LinearLayout>

</FrameLayout>